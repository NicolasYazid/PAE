<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="1000.0" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.hope.UsuariosController">
    <children>
        <Label text="Tabla de usuarios" />
      <TableView prefHeight="200.0" prefWidth="890.0">
        <columns>
            <TableColumn minWidth="1.0" prefWidth="165.0" text="Matrícula" />
          <TableColumn prefWidth="231.0" text="Nombre" />
          <TableColumn prefWidth="212.0" text="Apellido paterno" />
            <TableColumn prefWidth="210.0" text="Apellido materno" />
            <TableColumn minWidth="0.0" prefWidth="141.0" text="Edad" />
        </columns>
      </TableView>
        <Button fx:id="btnHome" onAction="#switchToHome" text="Regresar a Home" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
